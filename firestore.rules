rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: results
    // Document ID: Auto-generated
    // Fields:
    //   - uid: string (required, immutable) - User ID of the submitter
    //   - teamName: string (required, immutable) - Name of the team
    //   - score: number (required, immutable) - Score out of 25
    //   - totalQuestions: number (required, immutable) - Total number of questions
    //   - submittedAt: timestamp (required, immutable) - Submission time
    //
    // ===============================================================
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.uid;
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function isValidResult(data) {
      return hasOnlyAllowedFields(['uid', 'teamName', 'score', 'totalQuestions', 'submittedAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.teamName is string && data.teamName.size() > 0 && data.teamName.size() <= 100 &&
             data.score is number && data.score >= 0 && data.score <= 15 &&
             data.totalQuestions is number && data.totalQuestions == 15 &&
             data.submittedAt is number;
    }
    
    match /results/{resultId} {
      // Anyone can read the leaderboard
      allow read: if true;
      
      // Users can create results (auth not strictly required if anonymous auth is disabled)
      allow create: if isValidResult(request.resource.data);
      
      // No updates or deletes allowed for test results
      allow update, delete: if false;
    }
  }
}
